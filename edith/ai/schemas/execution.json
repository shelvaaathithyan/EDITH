{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "const": "execution"
    },
    "goal": {
      "type": "string"
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "tool": {
            "type": "string"
          },
          "arguments": {
            "type": "object"
          }
        },
        "required": ["tool", "arguments"],
        "additionalProperties": false
      }
    },
    "requires_confirmation": {
      "type": "boolean"
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    }
  },
  "required": ["type", "goal", "steps", "requires_confirmation", "confidence"],
  "additionalProperties": false
}
